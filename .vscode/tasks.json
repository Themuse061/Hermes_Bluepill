{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "STM32F103 upload ",
            "type": "shell",
            "command": "cd ./Firmware/STM32F103/STM32F103_Hermes ; make upload",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "STM32F103 clean ",
            "type": "shell",
            "command": "cd ./Firmware/STM32F103/STM32F103_Hermes ; make clean",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build C test suite",
            "type": "shell",
            "command": "C:/Users/Muse/AppData/Roaming/xPacks/@xpack-dev-tools/gcc/14.2.0-2.1/.content/bin/gcc.exe",
            "args": [
                "-g",
                // 1. Compile all .c files in src
                "${workspaceFolder}/Software/src/*.c",
                // also include C_test_suite.c
                "${workspaceFolder}/Software/main_files/C_test_suite.c",
                // and in src/hermes_source
                "${workspaceFolder}/Software/src/hermes_source/*.c",
                // 2. Include header files (.h) from include
                "-I",
                "${workspaceFolder}/Software/include",
                "-I",
                "${workspaceFolder}/Universal_includes",
                // 3. (NEW) Tell linker to look inside 'src' for library files
                "-L",
                "${workspaceFolder}/Software/src",
                // 4. (NEW) Link against the DLL.
                // GCC assumes "lib" prefix and ".dll" suffix.
                // If your file is "libserialport-0.dll", use "-lserialport-0"
                // If your file is "libserialport.dll", use "-lserialport"
                "-lserialport",
                // 5. Output file
                "-o",
                "${workspaceFolder}/Software/compiled/C_test_suite.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "flash dark times",
            "type": "shell",
            "command": "platformio.exe run -d ${workspaceFolder}/Firmware/Ch32V003/dark_times --target upload --environment genericCH32V003F4P6",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "flash bootloader",
            "type": "shell",
            "command": "platformio.exe run -d ${workspaceFolder}/Firmware/Ch32V003/ch32v003_bootloader --target upload --environment genericCH32V003F4P6",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "flash CH32V003_Blinky_With_I2C",
            "type": "shell",
            "command": "platformio.exe run -d ${workspaceFolder}/Firmware/Ch32V003/CH32V003_Blinky_With_I2C --target upload --environment genericCH32V003F4P6",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
    ]
}