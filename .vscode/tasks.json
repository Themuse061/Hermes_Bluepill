{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "STM32F103 upload ",
            "type": "shell",
            "command": "cd ./STM32F103_Hermes ; make upload",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "STM32F103 clean ",
            "type": "shell",
            "command": "cd ./STM32F103_Hermes ; make clean",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build C",
            "type": "shell",
            "command": "C:/Users/Muse/AppData/Roaming/xPacks/@xpack-dev-tools/gcc/14.2.0-2.1/.content/bin/gcc.exe",
            "args": [
                "-g",
                // 1. Compile all .c files in src
                "${workspaceFolder}/C_serial_doer_stuffer/src/*.c",
                // 2. Include header files (.h) from include
                "-I",
                "${workspaceFolder}/C_serial_doer_stuffer/include",
                // 3. (NEW) Tell linker to look inside 'src' for library files
                "-L",
                "${workspaceFolder}/C_serial_doer_stuffer/src",
                // 4. (NEW) Link against the DLL.
                // GCC assumes "lib" prefix and ".dll" suffix.
                // If your file is "libserialport-0.dll", use "-lserialport-0"
                // If your file is "libserialport.dll", use "-lserialport"
                "-lserialport",
                // 5. Output file
                "-o",
                "${workspaceFolder}/C_serial_doer_stuffer/C_serial_doer_stuffer.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Upload dark times",
            "type": "shell",
            "command": "platformio.exe run -d ${workspaceFolder}/dark_times --target upload --environment genericCH32V003F4P6",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "flash bootloader",
            "type": "shell",
            "command": "platformio.exe run -d ${workspaceFolder}/ch32v003_bootloader --target upload --environment genericCH32V003F4P6",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "flash bootloader blinky test",
            "type": "shell",
            "command": "platformio.exe run -d ${workspaceFolder}/ch32v003_bootloader_blinky_test --target upload --environment genericCH32V003F4P6",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}