    "version": "0.2.0",
    "configurations": [
        {
            "cwd": "${workspaceRoot}",
            "executable": "Firmware/STM32F103/STM32F103_Hermes/generated/constant_name_elf.elf",
            "name": "Debug STM32F103",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "searchDir": [
                "C:/embedded_programming/_Cerys_Modules/openocd-v0.12.0-i686-w64-mingw32/share/openocd"
            ],
            "configFiles": [
                "scripts/interface/stlink.cfg",
                "target/stm32f1x_clone_fix.cfg"
            ],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        },
        {
            "name": "debug C test suite",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Software/compiled/C_test_suite.exe",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/Software",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/Users/Muse/AppData/Roaming/xPacks/@xpack-dev-tools/gcc/14.2.0-2.1/.content/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
